rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read, write: if true;
    }

    match /initiatives/{initiativeId} {
      allow read, write: if true;
      
      match /tasks/{taskId} {
        allow read, write: if true;
      }
    }

    // Allow collectionGroup queries for tasks
    match /{path=**}/tasks/{taskId} {
      allow read: if true;
    }

    match /sessions/{sessionId} {
      allow read, write: if true;
    }

    match /mailbox/{postId} {
      allow read, write: if true;
      
      match /responses/{responseId} {
        allow read, write: if true;
      }
    }

    match /v1imagine/{postId} {
      allow read, write: if true;
    }

    match /news/{newsId} {
      allow read, write: if true;
    }
  }
}

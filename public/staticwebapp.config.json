{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/public/*", "/*.{png,jpg,gif,svg,ico,js,css}"]
  },
  "routes": [
    {
      "route": "/api/*",
      "methods": ["GET", "POST", "PUT", "DELETE"],
      "allowedRoles": ["anonymous", "authenticated"]
    }
  ],
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html",
      "statusCode": 200
    }
  }
}
